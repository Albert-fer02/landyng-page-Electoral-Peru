function calcScore(candidate, weights) {
  let total = 0;
  let totalWeight = 0;
  weights.forEach(c => {
    total += candidate.scores[c.key] * c.weight;
    totalWeight += c.weight;
  });
  return ((total / totalWeight) * 10).toFixed(1);
}

function ScoreBar({ value, max = 10, color }) {
  const pct = (value / max) * 100;
  return (
    <div style={{ width: "100%", height: 6, background: "rgba(255,255,255,0.06)", borderRadius: 3 }}>
      <div style={{ width: `${pct}%`, height: "100%", background: color, borderRadius: 3, transition: "width 0.5s ease" }} />
    </div>
  );
}

function TrendBadge({ trend }) {
  const map = { subiendo: { icon: "↑", color: "#06D6A0" }, bajando: { icon: "↓", color: "#E63946" }, estable: { icon: "→", color: "#888" }, variable: { icon: "↕", color: "#FFB703" } };
  const t = map[trend] || map.estable;
  return <span style={{ color: t.color, fontWeight: 600, fontSize: 11, letterSpacing: 1 }}>{t.icon} {trend.toUpperCase()}</span>;
}

